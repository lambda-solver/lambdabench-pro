# ── Local dev mode ────────────────────────────────────────────────────────────
# Set to true to skip live OpenRouter fetch and use mock top-models.
# No API key needed. Disable for real benchmark runs.
DEV_MODE=true

# ── OpenRouter ─────────────────────────────────────────────────────────────────
# Required for real runs (DEV_MODE=false). Get your key at openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# ── Model override ─────────────────────────────────────────────────────────────
# Comma-separated fallback if live fetch fails (or as alternative to DEV_MODE)
# TOP_MODELS=google/gemini-2.5-pro,anthropic/claude-opus-4
