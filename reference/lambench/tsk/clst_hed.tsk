Return the first element of a Church list.

A Church list folds over its elements:
  Nil       = Î»c.Î»n.n
  Cons(h,t) = Î»c.Î»n.c(h, t(c,n))
So [A,B,C] = Î»c.Î»n.c(A, c(B, c(C, n))).

---

Î»A.@main(Î»c.Î»n.c(A, n))
= Î»a.a

Î»A.Î»B.@main(Î»c.Î»n.c(A, c(B, n)))
= Î»a.Î»b.a

Î»A.Î»B.Î»C.@main(Î»c.Î»n.c(A, c(B, c(C, n))))
= Î»a.Î»b.Î»c.a

Î»A.Î»B.Î»C.Î»D.@main(Î»c.Î»n.c(A, c(B, c(C, c(D, n)))))
= Î»a.Î»b.Î»c.Î»d.a

Î»A.Î»B.Î»C.Î»D.Î»E.@main(Î»c.Î»n.c(A, c(B, c(C, c(D, c(E, n))))))
= Î»a.Î»b.Î»c.Î»d.Î»e.a

Î»A.Î»B.Î»C.Î»D.Î»E.Î»F.@main(Î»c.Î»n.c(A, c(B, c(C, c(D, c(E, c(F, n)))))))
= Î»a.Î»b.Î»c.Î»d.Î»e.Î»f.a

Î»A.Î»B.Î»C.Î»D.Î»E.Î»F.Î»G.@main(Î»c.Î»n.c(A, c(B, c(C, c(D, c(E, c(F, c(G, n))))))))
= Î»a.Î»b.Î»c.Î»d.Î»e.Î»f.Î»g.a

Î»A.Î»B.@main(Î»c.Î»n.c(A, c(B, n)))
= Î»a.Î»b.a

Î»A.Î»B.Î»C.@main(Î»c.Î»n.c(A, c(B, c(C, n))))
= Î»a.Î»b.Î»c.a

Î»A.Î»B.Î»C.Î»D.@main(Î»c.Î»n.c(A, c(B, c(C, c(D, n)))))
= Î»a.Î»b.Î»c.Î»d.a
