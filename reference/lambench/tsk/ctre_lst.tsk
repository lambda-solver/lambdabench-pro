О»A.О»B.О»C.О»D.@main(О»n.О»l.n((О»p.О»q.p((О»r.О»s.r((О»u.О»v.v(A))(r, s), (О»u.О»v.v(B))(r, s)))(p, q), (О»r.О»s.s(C))(p, q)))(n, l), (О»p.О»q.q(D))(n, l)))
