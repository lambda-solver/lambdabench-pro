Return the element at index I (Church nat, 0-based)
of an N-tuple.

An N-tuple packs N elements into one function:
  Î»t.t(A,B,C,...)
The size N is passed as a Church nat.

---

Î»A.Î»B.Î»C.@main(Î»f.Î»x.f(f(f(x))), Î»f.Î»x.x, Î»t.t(A,B,C))
= Î»a.Î»b.Î»c.a

Î»A.Î»B.Î»C.@main(Î»f.Î»x.f(f(f(x))), Î»f.Î»x.f(x), Î»t.t(A,B,C))
= Î»a.Î»b.Î»c.b

Î»A.Î»B.Î»C.@main(Î»f.Î»x.f(f(f(x))), Î»f.Î»x.f(f(x)), Î»t.t(A,B,C))
= Î»a.Î»b.Î»c.c

Î»A.Î»B.Î»C.Î»D.@main(Î»f.Î»x.f(f(f(f(x)))), Î»f.Î»x.x, Î»t.t(A,B,C,D))
= Î»a.Î»b.Î»c.Î»d.a

Î»A.Î»B.Î»C.Î»D.@main(Î»f.Î»x.f(f(f(f(x)))), Î»f.Î»x.f(f(x)), Î»t.t(A,B,C,D))
= Î»a.Î»b.Î»c.Î»d.c

Î»A.Î»B.Î»C.Î»D.@main(Î»f.Î»x.f(f(f(f(x)))), Î»f.Î»x.f(f(f(x))), Î»t.t(A,B,C,D))
= Î»a.Î»b.Î»c.Î»d.d

Î»A.Î»B.Î»C.Î»D.Î»E.@main(Î»f.Î»x.f(f(f(f(f(x))))), Î»f.Î»x.f(x), Î»t.t(A,B,C,D,E))
= Î»a.Î»b.Î»c.Î»d.Î»e.b

Î»A.Î»B.Î»C.Î»D.Î»E.@main(Î»f.Î»x.f(f(f(f(f(x))))), Î»f.Î»x.f(f(f(f(x)))), Î»t.t(A,B,C,D,E))
= Î»a.Î»b.Î»c.Î»d.Î»e.e

Î»A.Î»B.Î»C.Î»D.Î»E.Î»F.@main(Î»f.Î»x.f(f(f(f(f(f(x)))))), Î»f.Î»x.f(f(f(x))), Î»t.t(A,B,C,D,E,F))
= Î»a.Î»b.Î»c.Î»d.Î»e.Î»f.d

Î»A.Î»B.Î»C.Î»D.Î»E.Î»F.Î»G.@main(Î»f.Î»x.f(f(f(f(f(f(f(x))))))), Î»f.Î»x.f(f(f(f(f(x))))), Î»t.t(A,B,C,D,E,F,G))
= Î»a.Î»b.Î»c.Î»d.Î»e.Î»f.Î»g.f
