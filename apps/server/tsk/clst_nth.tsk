Return the element at index I (Church nat, 0-based)
of a Church list.

A Church list folds over its elements:
  Nil       = Î»c.Î»n.n
  Cons(h,t) = Î»c.Î»n.c(h, t(c,n))
So [A,B,C] = Î»c.Î»n.c(A, c(B, c(C, n))).

A Church nat:
  0 = Î»f.Î»x.x
  1 = Î»f.Î»x.f(x)
  2 = Î»f.Î»x.f(f(x))

---

Î»A.Î»B.Î»C.@main(Î»f.Î»x.x, Î»c.Î»n.c(A, c(B, c(C, n))))
= Î»a.Î»b.Î»c.a

Î»A.Î»B.Î»C.@main(Î»f.Î»x.f(x), Î»c.Î»n.c(A, c(B, c(C, n))))
= Î»a.Î»b.Î»c.b

Î»A.Î»B.Î»C.@main(Î»f.Î»x.f(f(x)), Î»c.Î»n.c(A, c(B, c(C, n))))
= Î»a.Î»b.Î»c.c

Î»A.Î»B.Î»C.Î»D.@main(Î»f.Î»x.x, Î»c.Î»n.c(A, c(B, c(C, c(D, n)))))
= Î»a.Î»b.Î»c.Î»d.a

Î»A.Î»B.Î»C.Î»D.@main(Î»f.Î»x.f(f(x)), Î»c.Î»n.c(A, c(B, c(C, c(D, n)))))
= Î»a.Î»b.Î»c.Î»d.c

Î»A.Î»B.Î»C.Î»D.@main(Î»f.Î»x.f(f(f(x))), Î»c.Î»n.c(A, c(B, c(C, c(D, n)))))
= Î»a.Î»b.Î»c.Î»d.d

Î»A.Î»B.Î»C.Î»D.Î»E.@main(Î»f.Î»x.f(x), Î»c.Î»n.c(A, c(B, c(C, c(D, c(E, n))))))
= Î»a.Î»b.Î»c.Î»d.Î»e.b

Î»A.Î»B.Î»C.Î»D.Î»E.@main(Î»f.Î»x.f(f(f(f(x)))), Î»c.Î»n.c(A, c(B, c(C, c(D, c(E, n))))))
= Î»a.Î»b.Î»c.Î»d.Î»e.e

Î»A.Î»B.Î»C.Î»D.Î»E.Î»F.@main(Î»f.Î»x.f(f(f(x))), Î»c.Î»n.c(A, c(B, c(C, c(D, c(E, c(F, n)))))))
= Î»a.Î»b.Î»c.Î»d.Î»e.Î»f.d

Î»A.Î»B.Î»C.Î»D.Î»E.Î»F.Î»G.@main(Î»f.Î»x.f(f(f(f(f(x))))), Î»c.Î»n.c(A, c(B, c(C, c(D, c(E, c(F, c(G, n))))))))
= Î»a.Î»b.Î»c.Î»d.Î»e.Î»f.Î»g.f
