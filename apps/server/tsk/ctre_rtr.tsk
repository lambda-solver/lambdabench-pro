О»A.@main(О»n.О»l.l(A))
= О»a.О»b.О»c.c(a)

О»A.@main(О»n.О»l.l(A))
= О»a.О»b.О»c.c(a)

О»A.О»B.@main(О»n.О»l.n(l(A), l(B)))
= О»a.О»b.О»c.О»d.c(d(b), d(a))

О»A.О»B.@main(О»n.О»l.n(l(A), l(B)))
= О»a.О»b.О»c.О»d.c(d(b), d(a))

О»A.О»B.О»C.О»D.@main(О»n.О»l.n(n(l(A), l(B)), n(l(C), l(D))))
