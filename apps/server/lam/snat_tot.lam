@zero = Î»s.Î»z.z
@succ = Î»n.Î»s.Î»z.s(n)
@pred = Î»n.n(Î»p.p)(@zero)
@true = Î»a.Î»b.a
@false = Î»a.Î»b.b
@isZero = Î»n.n(Î»p.@false)(@true)
@sub = Î»a.Î»b.b(Î»p.@pred(@sub(a,p)))(a)
@leq = Î»a.Î»b.@isZero(@sub(a,b))
@lt = Î»a.Î»b.@leq(@succ(a),b)
@mod = Î»a.Î»b.@lt(a,b)(a)(@mod(@sub(a,b),b))
@gcd = Î»a.Î»b.@isZero(b)(a)(@gcd(b,@mod(a,b)))
