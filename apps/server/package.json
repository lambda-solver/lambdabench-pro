{
  "name": "server",
  "version": "0.0.1",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "description": "Effect Platform HTTP API for the LamBench Pro benchmark server.",
  "keywords": [
    "lambda-calculus",
    "benchmark",
    "effect",
    "bun",
    "server"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir=dist --target=bun --minify --sourcemap",
    "build:types": "tsc --emitDeclarationOnly",
    "dev": "bun --watch run src/index.ts",
    "start": "bun run src/index.ts",
    "test": "vitest run",
    "type-check": "tsc --noEmit",
    "clean": "git clean -xdf .cache .turbo dist node_modules"
  },
  "dependencies": {
    "@effect/platform-bun": "4.0.0-beta.41",
    "@repo/domain": "workspace:*",
    "effect": "4.0.0-beta.41"
  },
  "devDependencies": {
    "@effect/language-service": "^0.81.0",
    "@effect/vitest": "4.0.0-beta.41",
    "@repo/config-typescript": "workspace:*",
    "@types/bun": "1.3.11",
    "vitest": "^4.1.0"
  }
}
