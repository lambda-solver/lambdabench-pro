# Base URL for GitHub Pages deployment
# Set to your repo path, e.g. /lambench-pro/ or /my-username/lambench-pro/
# Leave as / for local development
VITE_BASE_URL=/

# Enable Effect DevTools in the browser (optional)
VITE_ENABLE_DEVTOOLS=false

# OpenRouter API key — only needed when running the eval runner locally
# OPENROUTER_API_KEY=sk-or-...
