# Copy this file to .env and fill in the values

# The values in this file are used by the docker-compose.yml file to set the environment variables for the containers

# Change the values of the variables below to match your local environment

# Server
SERVER_PORT=9000
SERVER_HOST=localhost # <- Change this to your local IP address

# Client
CLIENT_PORT=3000

# AI
ANTHROPIC_API_KEY=

# LamBench RLM
OPENROUTER_API_KEY=your_key_here
LLM_MODEL=minimax/minimax-m2.5:free
RLM_MAX_DEPTH=3